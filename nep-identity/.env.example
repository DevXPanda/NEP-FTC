# nep-identity — environment configuration (copy to .env and fill in real values)

# HTTP port
PORT=3000

# PostgreSQL connection string for the identity schema
NEP_IDENTITY_DB_URL=postgresql://user:password@localhost:5432/nep?schema=identity

# JWT signing secrets
JWT_SECRET=change-me-access-token-secret
JWT_REFRESH_SECRET=change-me-refresh-token-secret

# Token lifetimes (seconds): access = 15m, refresh = 30d
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000

# Redis cache connection string
REDIS_URL=redis://localhost:6379

# RabbitMQ broker connection string + shared events exchange
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=nep.events
