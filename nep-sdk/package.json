{
  "name": "@nep/sdk",
  "version": "0.0.0",
  "description": "Shared SDK for NEP (NKTech Enterprise Platform) microservices — logging, errors, JWT auth, messaging, HTTP, and cache.",
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "access": "restricted"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./messaging": {
      "types": "./dist/messaging/index.d.ts",
      "default": "./dist/messaging/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "default": "./dist/cache/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "amqplib": "^0.10.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0"
  },
  "peerDependenciesMeta": {
    "amqplib": { "optional": true },
    "ioredis": { "optional": true },
    "jsonwebtoken": { "optional": true }
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "amqplib": "^0.10.4",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
